# Plantilla de variables de entorno del proyecto.
# 1. Copia este archivo como ".env" (sin ".example") en la raiz del repositorio.
# 2. Rellena cada valor con tus propias credenciales.
# 3. NUNCA subas el archivo ".env" real a git — ya esta excluido en .gitignore.
# 4. En Hugging Face Spaces, carga estas mismas variables (con los mismos nombres)
#    en: Space settings -> Variables and secrets.

# --- API WAQI (aqicn.org) ---
# Token gratuito personal, se obtiene en https://aqicn.org/data-platform/token/
WAQI_API_TOKEN=

# --- Supabase (base de datos del CRUD, Panel 4) ---
# Se obtienen en el panel de tu proyecto de Supabase: Project Settings -> API
# Si se dejan vacios, la app usa un fallback local SQLite (data_cache/consultas_local.db)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- SENAMHI (dataset historico) ---
# URL de descarga directa del CSV oficial (dejar el valor por defecto salvo que cambie el portal)
SENAMHI_CSV_URL=https://www.datosabiertos.gob.pe/sites/default/files/Monitoreo%20de%20los%20contaminantes%20del%20aire%20en%20Lima%20Metropolitana%20-%20%5BServicio%20Nacional%20de%20Meteorolog%C3%ADa%20e%20Hidrolog%C3%ADa%20del%20Per%C3%BA%20-%20SENAMHI%5D_1.csv

# --- Entorno ---
# "development" en local, "production" cuando corre en Hugging Face Spaces
APP_ENV=development
